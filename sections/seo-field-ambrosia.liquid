{% if collection.metafields.custom.image_seo_block
  or collection.metafields.custom.title_seo_block
  or collection.metafields.custom.text_seo_block
  or collection.metafields.custom.link_seo_block
%}
  <section class="seo-block-section">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-md-6 seo-block-image">
          {% if collection.metafields.custom.image_seo_block %}
            <img
              src="{{ collection.metafields.custom.image_seo_block | image_url: width: 800 }}"
              alt="{{ collection.metafields.custom.image_seo_block.alt | escape }}"
              class="img-fluid" width="{{ collection.metafields.custom.image_seo_block.width }}" height="{{ collection.metafields.custom.image_seo_block.height }}">
          {% endif %}
        </div>

        <div class="col-md-6">
          {% if collection.metafields.custom.title_seo_block %}
            <h2>{{ collection.metafields.custom.title_seo_block }}</h2>
          {% endif %}

          {% if collection.metafields.custom.text_seo_block %}
            <p>{{ collection.metafields.custom.text_seo_block }}</p>
          {% endif %}

          {% if collection.metafields.custom.link_seo_block %}
            {% assign link_text_raw = collection.metafields.custom.link_seo_block %}

            {% assign url_start = link_text_raw | split: '"url":"' %}
            {% assign url_split = url_start[1] | split: '"' %}
            {% assign real_url = url_split[0] %}

            {% assign text_start = link_text_raw | split: '"text":"' %}
            {% assign text_split = text_start[1] | split: '"' %}
            {% assign real_text = text_split[0] %}

            <a href="{{ real_url }}" class="btn btn-outline-primary">
              {{ real_text }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "SEO Collection Block",
  "presets": [
    {
      "name": "SEO Collection Block"
    }
  ]
}
{% endschema %}
