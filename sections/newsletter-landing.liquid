{{ 'section-newsletter-landing.css' | asset_url | stylesheet_tag }}

<div class="newsletter-landing-page color-{{ section.settings.color_scheme }} gradient">

  {%- if section.settings.show_background_image and section.settings.background_image != blank -%}
    <div class="newsletter-landing__background">
      <img
        src="{{ section.settings.background_image | image_url: width: 1920 }}"
        alt=""
        loading="lazy"
        width="1920"
        height="1080"
        class="newsletter-landing__bg-image"
      >
      <div class="newsletter-landing__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
    </div>
  {%- endif -%}

  <div class="newsletter-landing__content page-width">

    {%- if section.settings.logo != blank -%}
      <div class="newsletter-landing__logo">
        <img
          src="{{ section.settings.logo | image_url: width: 200 }}"
          alt="{{ shop.name }}"
          width="200"
          height="auto"
          loading="eager"
        >
      </div>
    {%- endif -%}

    {%- if section.settings.eyebrow_text != blank -%}
      <p class="newsletter-landing__eyebrow">{{ section.settings.eyebrow_text }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="newsletter-landing__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <div class="newsletter-landing__subheading rte">
        {{ section.settings.subheading }}
      </div>
    {%- endif -%}

    <div class="newsletter-landing__form-wrapper">
      {%- form 'customer', id: 'NewsletterLandingForm', class: 'newsletter-landing__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">

        {%- if form.posted_successfully? -%}
          <div class="newsletter-landing__success" role="status">
            <svg aria-hidden="true" focusable="false" class="icon icon-success" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <p>{{ section.settings.success_message }}</p>
          </div>
        {%- elsif form.errors -%}
          <div class="newsletter-landing__error" role="alert">
            <svg aria-hidden="true" focusable="false" class="icon icon-error" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="8" x2="12" y2="12"></line>
              <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
            <p>{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</p>
          </div>
        {%- else -%}
          <div class="newsletter-landing__field-group">
            {%- if section.settings.show_name_field -%}
              <div class="newsletter-landing__field">
                <label class="field__label visually-hidden" for="NewsletterFirstName">
                  {{ 'newsletter.label_first_name' | t }}
                </label>
                <input
                  id="NewsletterFirstName"
                  type="text"
                  name="contact[first_name]"
                  class="field__input"
                  value="{{ form.first_name }}"
                  aria-required="false"
                  autocomplete="given-name"
                  placeholder="{{ 'newsletter.label_first_name' | t }}"
                >
              </div>
            {%- endif -%}

            <div class="newsletter-landing__field">
              <label class="field__label visually-hidden" for="NewsletterEmail">
                {{ 'newsletter.label' | t }}
              </label>
              <input
                id="NewsletterEmail"
                type="email"
                name="contact[email]"
                class="field__input"
                value="{{ form.email }}"
                aria-required="true"
                autocomplete="email"
                placeholder="{{ 'newsletter.label' | t }}"
                {% if form.errors contains 'email' %}
                  aria-invalid="true"
                  aria-describedby="NewsletterEmailError"
                {% endif %}
              >
            </div>

            <button
              type="submit"
              class="newsletter-landing__submit button button--primary"
              name="commit"
              id="Subscribe"
              aria-label="{{ 'newsletter.button_label' | t }}"
            >
              {{ section.settings.button_label | default: 'newsletter.button_label' | t }}
              <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </button>
          </div>
        {%- endif -%}
      {%- endform -%}

      {%- if section.settings.privacy_note != blank -%}
        <p class="newsletter-landing__privacy">{{ section.settings.privacy_note }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <ul class="newsletter-landing__benefits" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'benefit' -%}
            <li class="newsletter-landing__benefit" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != 'none' -%}
                <span class="newsletter-landing__benefit-icon">
                  {%- render 'icon-benefit', icon: block.settings.icon -%}
                </span>
              {%- endif -%}
              <span class="newsletter-landing__benefit-text">{{ block.settings.text }}</span>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Newsletter landing page",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow text",
      "default": "Exclusive members only"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the OnlyChampsClub"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Sign up for exclusive deals, early access to new products, and insider tips delivered straight to your inbox.</p>"
    },
    {
      "type": "header",
      "content": "Form"
    },
    {
      "type": "checkbox",
      "id": "show_name_field",
      "label": "Show first name field",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe now",
      "info": "Leave blank to use theme default"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thanks for subscribing! Check your inbox for a confirmation email."
    },
    {
      "type": "text",
      "id": "privacy_note",
      "label": "Privacy note",
      "default": "By subscribing you agree to our Privacy Policy. Unsubscribe at any time."
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" },
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "inverse", "label": "Inverse" }
      ],
      "default": "background-1",
      "label": "Color scheme"
    },
    {
      "type": "checkbox",
      "id": "show_background_image",
      "label": "Show background image",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Background image overlay opacity",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "checkmark", "label": "Checkmark" },
            { "value": "star", "label": "Star" },
            { "value": "gift", "label": "Gift" },
            { "value": "tag", "label": "Tag" }
          ],
          "default": "checkmark"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Benefit text",
          "default": "Exclusive member discounts"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Newsletter landing page",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "checkmark",
            "text": "Exclusive member discounts"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "checkmark",
            "text": "Early access to new products"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "checkmark",
            "text": "Free shipping on first order"
          }
        }
      ]
    }
  ]
}
{% endschema %}
