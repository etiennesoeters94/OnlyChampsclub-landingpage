{{ 'customer.aio.min.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- if section.settings.enable_shop_login_button == false -%}
  {%- assign hide_shop_login_button = true -%}
{%- endif -%}

<section class="login-panel">
  <div class="customer login section-{{ section.id }}-padding">
    <div class="form-recover" id="recover">
      <h2 id="recover" tabindex="-1">Wachtwoord vergeten?</h2>
      <div>
        {%- form 'recover_customer_password' -%}
          {% assign recover_success = form.posted_successfully? %}
          <div class="field">
            <input
              type="email"
              value=""
              name="email"
              id="RecoverEmail"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              {% if form.errors %}
                aria-invalid="true"
                aria-describedby="RecoverEmail-email-error"
                autofocus
              {% endif %}
              placeholder="example@gmail.com"
            >
            <label for="RecoverEmail"> E-mail </label>
          </div>
          {%- if form.errors -%}
            <small id="RecoverEmail-email-error" class="form__message">
              <span class="svg-wrapper">
                {{- 'icon-error.svg' | inline_asset_content -}}
              </span>
              {{ form.errors.messages.form }}
            </small>
          {%- endif -%}

          <button class="recover">Vraag nieuw wachtwoord aan</button>
          <a href="{{ routes.account_register_url }}" class="create-account">
            Geen account? <span>Registreer je</span>
          </a>
        {%- endform -%}
      </div>
    </div>

    <div class="form-login">
      {%- if recover_success == true -%}
        <h3 class="form__message" tabindex="-1" autofocus>
          <span class="svg-wrapper">
            {{- 'icon-success.svg' | inline_asset_content -}}
          </span>
          {{ 'customer.recover_password.success' | t }}
        </h3>
      {%- endif -%}
      <h2 id="login" tabindex="-1">Inloggen</h2>
      {%- form 'customer_login', novalidate: 'novalidate' -%}
        <input type="hidden" name="return_to" value="/account">

        {%- if form.errors -%}
          <h2 class="form__message" tabindex="-1" autofocus>
            <span class="visually-hidden">{{ 'accessibility.error' | t }} </span>
            <span class="svg-wrapper">
              {{- 'icon-error.svg' | inline_asset_content -}}
            </span>
            {{ 'templates.contact.form.error_heading' | t }}
          </h2>
          <div class="errors">
            <ul>
              <li>Onjuist e-mailadres of wachtwoord.</li>
            </ul>
          </div>
        {%- endif -%}

        {%- if shop.features.login_with_shop_classic_customer_accounts? -%}
          <section name="sign-in-with-shop-provider">
            {{ shop | login_button: hide_button: hide_shop_login_button }}

            {%- unless hide_shop_login_button -%}
              <p>
                {{ 'customer.login_page.alternate_provider_separator' | t }}
              </p>
            {%- endunless -%}
          </section>
        {%- endif -%}

        <div class="field">
          <input
            type="email"
            name="customer[email]"
            id="CustomerEmail"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            {% if form.errors contains 'form' %}
              aria-invalid="true"
            {% endif %}
            placeholder="E-mail"
          >
          <label for="CustomerEmail"> E-mail </label>
        </div>

        {%- if form.password_needed -%}
          <div class="field">
            <input
              type="password"
              value=""
              name="customer[password]"
              id="CustomerPassword"
              autocomplete="current-password"
              {% if form.errors contains 'form' %}
                aria-invalid="true"
              {% endif %}
              placeholder="Wachtwoord"
            >
            <label for="CustomerPassword"> Wachtwoord </label>
          </div>

          <a href="#recover"> Wachtwoord vergeten? </a>
        {%- endif -%}

        <button>Inloggen</button>

        <a href="{{ routes.account_register_url }}" class="create-account">
          Geen account? <span>Registreer je</span>
        </a>
      {%- endform -%}
    </div>

    {%- if shop.checkout.guest_login -%}
      <div>
        <hr>
        <h2>{{ 'customer.login_page.guest_title' | t }}</h2>

        {%- form 'guest_login' -%}
          <button>
            {{ 'customer.login_page.guest_continue' | t }}
          </button>
        {%- endform -%}
      </div>
    {%- endif -%}
  </div>
</section>
<script>
  function toggleLoginRecoverForms() {
    const loginForm = document.querySelector('.form-login');
    const recoverForm = document.querySelector('.form-recover');
    const hash = window.location.hash;

    if (!loginForm || !recoverForm) return;

    if (hash === '#recover') {
      loginForm.style.display = 'none';
      recoverForm.style.display = 'block';

      setTimeout(() => {
        const target = document.querySelector('#recover');
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      }, 100);
    } else {
      loginForm.style.display = 'block';
      recoverForm.style.display = 'none';
    }
  }

  toggleLoginRecoverForms();

  document.addEventListener('DOMContentLoaded', function () {
    toggleLoginRecoverForms();
  });

  document.querySelectorAll('a[href="#recover"]').forEach((link) => {
    link.addEventListener('click', function (e) {
      e.preventDefault();
      history.pushState(null, '', '#recover');
      toggleLoginRecoverForms();
    });
  });
</script>

{% schema %}
{
  "name": "t:sections.main-login.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_shop_login_button",
      "label": "t:sections.main-login.shop_login_button.enable",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
