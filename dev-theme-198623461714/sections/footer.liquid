<div
  class="modal fade"
  id="firstOrderDiscountModal"
  tabindex="-1"
  aria-labelledby="discountModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content p-4">
      <div class="modal-header border-0">
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body text-center">
        <h5 class="modal-title">Word lid van OnlyChamps</h5>

        <p>Sluit je aan en krijg 10% korting op je eerste bubbels plus exclusieve releases en insider deals</p>

        <div class="footer-block__newsletter">
          {%- form 'customer', id: 'ContactFooterNews', class: 'newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="d-flex">
              <input
                id="NewsletterFormNewsModal"
                type="email"
                name="contact[email]"
                class="form-control"
                value="{{ form.email }}"
                placeholder="Vul je e-mailadres in"
                required
              >
              <button type="submit" class="btn btn-primary ms-2" name="commit" id="SubscribeNewsModal">
                Laat mij binnen
              </button>
            </div>
          {%- endform -%}
        </div>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="cartPopup" tabindex="-1" aria-labelledby="cartPopupLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content text-center p-4">
      <h5 class="mb-5" id="cartPopupLabel">Product toegevoegd aan winkelwagen!</h5>
      <div class="d-flex justify-content-center gap-3 align-items-center">
        <a href="#" class="btn btn-link close-and-refresh">Verder winkelen</a>

              <a href="{{ routes.cart_url }}" class="btn btn-primary">Ga naar winkelwagen</a>
      </div>
    </div>
  </div>
</div>

