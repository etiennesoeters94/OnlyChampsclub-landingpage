                <path d="M18.7651 9.19356H21.6588L21.9051 7.71066H18.7651V5.6401H21.7574L22.0283 4.06934H16.9489V4.11327V12.9832H21.9667L22.213 11.4124H18.7651V9.19356Z" fill="#2A3942"/>
