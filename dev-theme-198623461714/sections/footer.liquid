{% javascript %}
  document.addEventListener('DOMContentLoaded', function () {
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('customer_posted') === 'true') {
      const modal = new bootstrap.Modal(document.getElementById('newsletterSuccessModal'));
      modal.show();

      localStorage.setItem('userSubscribed', 'true');

      const newUrl = window.location.protocol + '//' + window.location.host + window.location.pathname;
      window.history.replaceState({}, document.title, newUrl);
    }
  });

  document.querySelectorAll('.logo-footer').forEach((logo) => {
    logo.addEventListener('mouseenter', () => {
      logo.querySelectorAll('i').forEach((i) => {
        const x = Math.random() * 200 - 100 + 'px';
        const y = Math.random() * 200 - 100 + 'px';
        const r = Math.random() * 360 + 'deg';
        const h = Math.floor(Math.random() * 360);
        i.style.setProperty('--x', x);
        i.style.setProperty('--y', y);
        i.style.setProperty('--r', r);
        i.style.backgroundColor = `hsl(${h}, 100%, 50%)`;
        i.style.animation = 'bang 700ms ease-out forwards';
      });
    });

    logo.addEventListener('mouseleave', () => {
      logo.querySelectorAll('i').forEach((i) => {
        i.style.animation = 'none';
        i.offsetHeight;
        i.style.opacity = 0;
      });
    });
  });

  window.copyCoupon = function () {
    var coupon = document.getElementById('couponCode');
    var range = document.createRange();
    range.selectNode(coupon);
    window.getSelection().removeAllRanges();
    window.getSelection().addRange(range);

    try {
      var successful = document.execCommand('copy');
      if (successful) {
        var copyMsg = document.getElementById('copyMessage');
        copyMsg.style.display = 'block';
        setTimeout(function () {
          copyMsg.style.display = 'none';
        }, 2000);
      } else {
        console.error('Copy command was unsuccessful');
      }
    } catch (err) {
      console.error('Oops, unable to copy', err);
    }

    window.getSelection().removeAllRanges();
  };

  document.querySelectorAll('.add-to-cart-link').forEach((link) => {
    link.addEventListener('click', function (e) {
      e.preventDefault();
      const variantId = this.getAttribute('data-variant-id');

      fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          id: variantId,
          quantity: 1,
        }),
      })
        .then((response) => response.json())
        .then((data) => {
          const cartPopup = new bootstrap.Modal(document.getElementById('cartPopup'));
          cartPopup.show();
        })
        .catch((error) => {
          console.error('Error adding to cart:', error);
        });
    });
  });

  document.addEventListener('DOMContentLoaded', function () {
    const champagneIcon = document.getElementById('champagneIcon');

    function hasSeenDiscountModal() {
      return sessionStorage.getItem('discountModalShown') === 'true';
    }

    function hasSubscribedToNewsletter() {
      return localStorage.getItem('userSubscribed') === 'true';
    }

    function shouldShowIcon() {
      var path = window.location.pathname;
      return /^\/products\/[^/]+$/.test(path) || /^\/collections\/[^/]+$/.test(path) || path === '/collections';
    }

    if (shouldShowIcon() && !hasSeenDiscountModal() && !hasSubscribedToNewsletter()) {
      champagneIcon.style.display = 'block';

      champagneIcon.addEventListener('click', function () {
        var discountModal = new bootstrap.Modal(document.getElementById('firstOrderDiscountModal'));
        discountModal.show();
        champagneIcon.style.display = 'none';
        sessionStorage.setItem('discountModalShown', 'true');
      });
    }

    if (!hasSeenDiscountModal() && !hasSubscribedToNewsletter()) {
      setTimeout(() => {
        const discountModal = new bootstrap.Modal(document.getElementById('firstOrderDiscountModal'));
        discountModal.show();
        sessionStorage.setItem('discountModalShown', 'true');
      }, 5000);
    }

    function triggerBounce() {
      champagneIcon.style.animation = 'anime-bounce 1s ease';
      setTimeout(() => {
        champagneIcon.style.animation = '';
      }, 1000);
    }

    setInterval(triggerBounce, 20000);
    triggerBounce();
  });

  document.querySelector('.close-and-refresh')?.addEventListener('click', function (e) {
    e.preventDefault();
    const modal = bootstrap.Modal.getInstance(document.getElementById('cartPopup'));
    modal.hide();
    setTimeout(() => {
      location.reload();
    }, 300);
  });

  document.addEventListener('DOMContentLoaded', function () {
    const icon = document.getElementById('champagneIcon');

    function triggerBounce() {
      icon.style.animation = 'anime-bounce 1s ease';

      setTimeout(() => {
        icon.style.animation = '';
      }, 1000);
    }

    setInterval(triggerBounce, 20000);

    triggerBounce();
  });
{% endjavascript %}
