<section class="custom-blog-article">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        {% if article.title %}
          <h1 class="text-center">{{ article.title }}</h1>
        {% endif %}

        {% if article.excerpt != blank %}
          <div class="excerpt text-center">{{ article.excerpt }}</div>
        {% endif %}
        <div class="d-flex justify-content-between align-items-center box-top">
          {% assign word_count = article.content | strip_html | split: ' ' | size %}
          {% assign reading_time = word_count | divided_by: 200 | ceil %}
          <p class="text-time">{{ reading_time }} min leestijd</p>
          <div class="product-share">
            <div class="d-flex align-items-center gap-3 position-relative">
              <!-- Kopieer Link Knop -->
