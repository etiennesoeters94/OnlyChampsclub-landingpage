{% assign scheme1 = settings.color_schemes | first %}
{%- if section.settings.color_scheme == scheme1 -%}<hr>{%- endif -%}
<div class="password__footer color-{{ section.settings.color_scheme }} gradient">
  <ul class="list-social list-unstyled" role="list">
    {%- if settings.social_instagram_link != blank -%}
      <li class="list-social__item">
        <a href="{{ settings.social_instagram_link }}" class="link list-social__link" title="Instagram">
          <span class="svg-wrapper">
            {{- 'icon-instagram.svg' | inline_asset_content -}}
          </span>
          <span class="visually-hidden">{{ 'general.social.links.instagram' | t }}</span>
        </a>
      </li>
    {%- endif -%}

    {%- if settings.social_facebook_link != blank -%}
      <li class="list-social__item">
        <a href="{{ settings.social_facebook_link }}" class="link list-social__link" title="Facebook">
          <span class="svg-wrapper">
            {{- 'icon-facebook.svg' | inline_asset_content -}}
          </span>
          <span class="visually-hidden">{{ 'general.social.links.facebook' | t }}</span>
        </a>
      </li>
    {%- endif -%}

    {%- if settings.social_tiktok_link != blank -%}
      <li class="list-social__item">
        <a href="{{ settings.social_tiktok_link }}" class="link list-social__link" title="TikTok">
          <span class="svg-wrapper">
            {{- 'icon-tiktok.svg' | inline_asset_content -}}
          </span>
          <span class="visually-hidden">{{ 'general.social.links.tiktok' | t }}</span>
        </a>
      </li>
    {%- endif -%}

    {%- if settings.social_google_link != blank -%}
      <li class="list-social__item">
        <a href="{{ settings.social_google_link }}" class="link list-social__link" title="Google">
          <span class="svg-wrapper">
            {{- 'icon-google.svg' | inline_asset_content -}}
          </span>
          <span class="visually-hidden">{{ 'general.social.links.google' | t }}</span>
        </a>
      </li>
    {%- endif -%}

    {%- if settings.social_google_business_link != blank -%}
      <li class="list-social__item">
        <a href="{{ settings.social_google_business_link }}" class="link list-social__link" title="Google Business">
          <span class="svg-wrapper">
            {{- 'icon-google-business.svg' | inline_asset_content -}}
          </span>
          <span class="visually-hidden">{{ 'general.social.links.google_business' | t }}</span>
        </a>
      </li>
    {%- endif -%}
    {%- if settings.social_whatsapp_link != blank -%}
      <li class="list-social__item">
        <a href="{{ settings.social_whatsapp_link }}" class="link list-social__link" title="Whastapp">
          <span class="svg-wrapper">
            {{- 'icon-whatsapp.svg' | inline_asset_content -}}
          </span>
          <span class="visually-hidden">{{ 'general.social.links.whatsapp' | t }}</span>
        </a>
      </li>
    {%- endif -%}
    {%- if settings.social_mail_link != blank -%}
      <li class="list-social__item">
        <a href="{{ settings.social_mail_link }}" class="link list-social__link" title="Email">
          <span class="svg-wrapper">
            {{- 'icon-mail.svg' | inline_asset_content -}}
          </span>
          <span class="visually-hidden">{{ 'general.social.links.mail' | t }}</span>
        </a>
      </li>
    {%- endif -%}
  </ul>
  {% capture shopify %}
    <a
      class="shopify-link"
      href="//www.shopify.com"
      rel="nofollow"
      target="_blank"
      aria-describedby="a11y-new-window-message"
      aria-label="Shopify"
    >
      {{ 'icon-shopify.svg' | inline_asset_content }}
    </a>
  {% endcapture %}
  <small class="password__footer-caption password__footer-text">
    {{- 'general.password_page.powered_by_shopify_html' | t: shopify: shopify -}}
  </small>
  <small class="password__footer-login password__footer-text">{{ 'general.password_page.admin_link_html' | t }}</small>
</div>

{% schema %}
{
  "name": "t:sections.main-password-footer.name",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
