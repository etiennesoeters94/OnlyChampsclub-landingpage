                <path d="M20 4.69727H4C2.897 4.69727 2 5.59427 2 6.69727V18.6973C2 19.8003 2.897 20.6973 4 20.6973H20C21.103 20.6973 22 19.8003 22 18.6973V6.69727C22 5.59427 21.103 4.69727 20 4.69727ZM20 6.69727V7.20827L12 13.4313L4 7.20927V6.69727H20ZM4 18.6973V9.74127L11.386 15.4863C11.5611 15.6238 11.7773 15.6986 12 15.6986C12.2227 15.6986 12.4389 15.6238 12.614 15.4863L20 9.74127L20.002 18.6973H4Z" fill="#2A3942"/>
