                <path d="M8.46395 17.6471L7.04895 16.2331L15.536 7.74707L16.95 9.16207L8.46395 17.6471Z" fill="#2A3942"/>
              </svg>
            </button>
            <span
              class="copied-msg position-absolute translate-middle mt-1 px-2 py-1 bg-dark text-white rounded small"
              style="display:none;"
            >
              Copied!
