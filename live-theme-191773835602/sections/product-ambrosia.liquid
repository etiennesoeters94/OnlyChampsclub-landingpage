                <path d="M22 12.6973C22 18.2201 17.5228 22.6973 12 22.6973C9.96818 22.6973 8.0779 22.0913 6.5 21.0502L2 22.6973L3.5 17.9677C2.54913 16.4374 2 14.6315 2 12.6973C2 7.17442 6.47715 2.69727 12 2.69727C17.5228 2.69727 22 7.17442 22 12.6973Z" stroke="#2A3942" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M9.65101 15.0432C11.834 17.2272 14.6 18.6192 16.245 16.9812L16.644 16.5822C17.176 16.0512 17.102 15.1712 16.484 14.7422C16.095 14.4712 15.677 14.1802 15.215 13.8552C14.737 13.5192 14.082 13.5722 13.667 13.9832L13.216 14.4312C12.657 14.0772 12.104 13.6222 11.59 13.1092L11.588 13.1072C11.075 12.5942 10.62 12.0402 10.266 11.4812L10.714 11.0302C11.126 10.6162 11.177 9.96021 10.842 9.48221C10.516 9.02021 10.225 8.60221 9.95501 8.21321C9.52601 7.59621 8.64601 7.52221 8.11501 8.05321L7.71601 8.45221C6.07901 10.0972 7.47001 12.8612 9.65301 15.0462" stroke="#2A3942" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
