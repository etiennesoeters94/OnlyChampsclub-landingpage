                <path d="M22 13.001C22 7.44445 17.5229 2.93994 12 2.93994C6.47715 2.93994 2 7.44445 2 13.001C2 18.0227 5.65684 22.1851 10.4375 22.9399V15.9093H7.89844V13.001H10.4375V10.7845C10.4375 8.2629 11.9305 6.87006 14.2146 6.87006C15.3088 6.87006 16.4531 7.06657 16.4531 7.06657V9.54255H15.1922C13.95 9.54255 13.5625 10.3182 13.5625 11.1138V13.001H16.3359L15.8926 15.9093H13.5625V22.9399C18.3432 22.1851 22 18.0229 22 13.001Z" fill="#2A3942"/>
