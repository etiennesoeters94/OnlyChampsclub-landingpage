<section class="product-hero-info text-center">
  <div class="container">
    <div class="row">
      <div class="col-md-6">
        {% if product.images.size > 0 %}
          <div class="first-image">
            {% assign featured = product.featured_media %}
            {% if featured.media_type == 'video' %}
              {% assign mp4_url = '' %}
              {% for source in featured.sources %}
                {% if source.format == 'mp4' %}
                  {% assign mp4_url = source.url %}
                  {% break %}
                {% endif %}
              {% endfor %}
              {% if mp4_url != '' %}
                <img
                  src="{{ featured.preview_image | image_url }}"
                  alt="{{ featured.alt | escape }}"
                  class="img-fluid gallery-image"
                  data-type="video"
                  data-src="{{ mp4_url }}"
                  data-poster="{{ featured.preview_image | image_url }}" width="{{ featured.preview_image.width }}" height="{{ featured.preview_image.height }}">
              {% endif %}
            {% elsif featured.media_type == 'external_video' and featured.host == 'youtube' %}
              <img
                src="{{ featured.preview_image | image_url }}"
                alt="{{ featured.alt | escape }}"
                class="img-fluid gallery-image"
                data-type="youtube"
                data-src="https://www.youtube.com/embed/{{ featured.external_id }}?autoplay=1&rel=0&modestbranding=1" width="{{ featured.preview_image.width }}" height="{{ featured.preview_image.height }}">
            {% else %}
              <img
                src="{{ product.featured_image | image_url }}"
                alt="{{ product.featured_image.alt | escape }}"
                class="img-fluid gallery-image"
                data-type="image"
                data-src="{{ product.featured_image | image_url }}" width="{{ product.featured_image.width }}" height="{{ product.featured_image.height }}">
            {% endif %}
          </div>

          <div class="row images-bottom mt-2">
            {% assign secondary_images = product.images | slice: 1, 2 %}
            {% for image in secondary_images %}
              <div class="col-6">
                <img
                  src="{{ image | image_url }}"
                  alt="{{ image.alt | escape }}"
                  class="img-fluid gallery-image"
                  data-type="image"
                  data-src="{{ image | image_url }}" width="{{ image.width }}" height="{{ image.height }}">
              </div>
            {% endfor %}

            {% for media in product.media %}
              {% if media.media_type == 'video' %}
                {% assign mp4_url = '' %}
                {% for source in media.sources %}
                  {% if source.format == 'mp4' %}
                    {% assign mp4_url = source.url %}
                    {% break %}
                  {% endif %}
                {% endfor %}
                {% if mp4_url != '' %}
                  <div class="col-6 position-relative video-thumb">
                    <img
                      src="{{ media.preview_image | image_url }}"
                      alt="Video"
                      class="img-fluid gallery-image"
                      data-type="video"
                      data-src="{{ mp4_url }}"
                      data-poster="{{ media.preview_image | image_url }}" width="{{ media.preview_image.width }}" height="{{ media.preview_image.height }}">
                    <span class="play-icon"></span>
                  </div>
                {% endif %}
              {% elsif media.media_type == 'external_video' and media.host == 'youtube' %}
                <div class="col-6 position-relative video-thumb">
                  <img
                    src="{{ media.preview_image | image_url }}"
                    alt="YouTube Video"
                    class="img-fluid gallery-image"
                    data-type="youtube"
                    data-src="https://www.youtube.com/embed/{{ media.external_id }}?autoplay=1&rel=0&modestbranding=1" width="{{ media.preview_image.width }}" height="{{ media.preview_image.height }}">
                  <span class="play-icon"></span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="col-md-6">
        <!-- <p class="product-vendor">Champagnemaker</p> -->
        <h1>{{ product.title }}</h1>

        <table class="table border-0">
          {% if product.metafields.custom.info_wijnkist != blank %}
            <tr>
             <td class="text-muted"></td>
            <td>{{ product.metafields.custom.info_wijnkist | metafield_tag }}</td>
            </tr>
           {% endif %}
          {% if product.metafields.custom.kijken %}
            <tr>
              <td class="text-muted">Kijken</td>
              <td>{{ product.metafields.custom.kijken | newline_to_br }}</td>
            </tr>
          {% endif %}
          {% if product.metafields.custom.ruiken %}
            <tr>
              <td class="text-muted">Ruiken</td>
              <td>{{ product.metafields.custom.ruiken | newline_to_br }}</td>
            </tr>
          {% endif %}
          {% if product.metafields.custom.smaak %}
            <tr>
              <td class="text-muted">Proeven</td>
              <td>{{ product.metafields.custom.smaak | newline_to_br }}</td>
            </tr>
          {% endif %}
          {% if product.metafields.custom.ingredi_nten %}
            <tr>
              <td class="text-muted">Druiven</td>
              <td>{{ product.metafields.custom.ingredi_nten | newline_to_br }}</td>
            </tr>
          {% endif %}
          {% if product.metafields.custom.appels %}
            <tr>
              <td class="text-muted">Appelsoort</td>
              <td>{{ product.metafields.custom.appels | newline_to_br }}</td>
            </tr>
          {% endif %}
          {% if product.metafields.custom.dosage %}
            <tr>
              <td class="text-muted">Dosage</td>
              <td>{{ product.metafields.custom.dosage | newline_to_br }}</td>
            </tr>
          {% endif %}
          {% if product.metafields.custom.serveertip %}
            <tr>
              <td class="text-muted">Serveertip</td>
              <td>{{ product.metafields.custom.serveertip | newline_to_br }}</td>
            </tr>
          {% endif %}
          {% if product.metafields.custom.perfect_bij %}
            <tr>
              <td class="text-muted">Perfect bij</td>
              <td>{{ product.metafields.custom.perfect_bij | newline_to_br }}</td>
            </tr>
          {% endif %}
        </table>

        {% assign first_variant = product.variants.first %}

        <p class="price">
          <span class="product-price__current">{{ first_variant.price | money }}</span>
          {% if first_variant.compare_at_price > first_variant.price %}
            <span class="product-price__compare">{{ first_variant.compare_at_price | money }}</span>
          {% endif %}
        </p>

        <form method="post" action="{{ routes.cart_add_url }}">
          <input type="hidden" name="id" value="{{ first_variant.id }}">

          <div class="d-block d-md-flex">
            {% if first_variant.inventory_quantity > 0 or first_variant.inventory_policy == 'continue' %}
              <div class="quantity-wrapper d-flex align-items-center justify-content-between" style="gap: 8px;">
                <button type="button" class="qty-btn minus btn">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="25" viewBox="0 0 24 25" fill="none">
                    <path d="M5 11.6973H19V13.6973H5V11.6973Z" fill="#2A3942"/>
                  </svg>
                </button>

                <input
                  type="text"
                  name="quantity"
                  value="1"
                  min="1"
                  class="form-control text-center"
                  style="max-width: 60px; height: 40px;"
                >

                <button type="button" class="qty-btn plus btn">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="25" viewBox="0 0 24 25" fill="none">
                    <path d="M19 11.6973H13V5.69727H11V11.6973H5V13.6973H11V19.6973H13V13.6973H19V11.6973Z" fill="#2A3942"/>
                  </svg>
                </button>
              </div>

              <div class="infos">
                <button type="submit" class="btn btn-primary">In Winkelwagen</button>
                <span class="text-bottom">Gratis verzending vanaf €150</span>
              </div>
            {% else %}
              <div class="infos sold">
                <div class="sold-out-text">Uitverkocht</div>
              </div>
            {% endif %}
          </div>
        </form>

        <div class="product-share">
          <span class="text-share d-block mb-2">Deel dit product:</span>
          <div class="d-flex align-items-center gap-3">
            <button type="button" class="btn p-0 copy-link" title="Kopieer link" aria-label="Copy link">
