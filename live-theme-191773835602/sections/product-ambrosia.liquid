</section>

<div id="galleryModal" class="modal fade" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content bg-transparent border-0">
      <div class="modal-body position-relative text-center p-0">
        <button
          type="button"
          class="btn-close position-absolute top-0 end-0 m-3"
          data-bs-dismiss="modal"
          aria-label="Close"
        ></button>
        <img id="modalImage" src="{{ product.featured_image | image_url: width: 1200 }}" alt="" class="img-fluid rounded" width="1200" height="1200">
        <button
          class="btn btn-light position-absolute start-0 top-50 translate-middle-y gallery-prev"
          style="z-index:10;"
        >
          ‹
        </button>
        <button
          class="btn btn-light position-absolute end-0 top-50 translate-middle-y gallery-next"
          style="z-index:10;"
        >
          ›
        </button>
      </div>
    </div>
  </div>
</div>

{% javascript %}
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.quantity-wrapper').forEach((wrapper) => {
      const input = wrapper.querySelector('input[name="quantity"]');
      const btnMinus = wrapper.querySelector('.qty-btn.minus');
      const btnPlus = wrapper.querySelector('.qty-btn.plus');

      btnMinus.addEventListener('click', () => {
        const current = parseInt(input.value, 10) || 1;
        input.value = Math.max(1, current - 1);
      });

      btnPlus.addEventListener('click', () => {
        const current = parseInt(input.value, 10) || 1;
        input.value = current + 1;
      });
    });
  });
  document.addEventListener('DOMContentLoaded', function () {
    const modal = document.getElementById('galleryModal');
    const modalBody = modal.querySelector('.modal-body');
    const images = Array.from(document.querySelectorAll('.gallery-image'));
    let currentIndex = 0;

    function getVideoMimeType(url) {
      const ext = url.split('.').pop().toLowerCase();
      switch (ext) {
        case 'mp4':
          return 'video/mp4';
        case 'webm':
          return 'video/webm';
        case 'mov':
          return 'video/quicktime';
        default:
          return 'video/mp4';
      }
    }

    function resetModalBody() {
      modalBody.innerHTML = `
      <button
        type="button"
        class="btn-close position-absolute top-0 end-0 m-3"
        data-bs-dismiss="modal"
        aria-label="Close"
      ></button>
      <button
        class="btn btn-light position-absolute start-0 top-50 translate-middle-y gallery-prev"
        style="z-index:10;"
      >
        ‹
      </button>
      <button
        class="btn btn-light position-absolute end-0 top-50 translate-middle-y gallery-next"
        style="z-index:10;"
      >
        ›
      </button>
    `;
    }

    function showMedia(index) {
      if (index < 0 || index >= images.length) return;
      currentIndex = index;

      const el = images[index];
      const type = el.dataset.type || 'image';
      const src = el.dataset.src || el.src;
      const poster = el.dataset.poster || '';
      let html = '';

      if (type === 'video') {
        const mime = getVideoMimeType(src);
        html = `
      <video class="w-100 rounded" controls autoplay playsinline poster="${poster}">
        <source src="${src}" type="${mime}">
        Your browser does not support the video tag.
      </video>
    `;
      } else if (type === 'youtube') {
        html = `
      <div class="ratio ratio-16x9">
        <iframe src="${src}" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
      </div>
    `;
      } else {
        html = `<img src="${src}" class="img-fluid rounded">`;
      }

      resetModalBody();
      modalBody.insertAdjacentHTML('afterbegin', html);

      modalBody.querySelector('.gallery-prev').addEventListener('click', () => {
        showMedia((currentIndex - 1 + images.length) % images.length);
      });

      modalBody.querySelector('.gallery-next').addEventListener('click', () => {
        showMedia((currentIndex + 1) % images.length);
      });

      bootstrap.Modal.getOrCreateInstance(modal).show();
    }

    images.forEach((img, i) => {
      img.addEventListener('click', () => showMedia(i));
    });

    document.querySelector('.gallery-prev')?.addEventListener('click', () => {
      showMedia((currentIndex - 1 + images.length) % images.length);
    });

    document.querySelector('.gallery-next')?.addEventListener('click', () => {
      showMedia((currentIndex + 1) % images.length);
    });

    modal.addEventListener('hidden.bs.modal', resetModalBody);
  });

  document.addEventListener('DOMContentLoaded', function () {
    const copyBtn = document.querySelector('.copy-link');

    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        const url = window.location.href;
        navigator.clipboard.writeText(url).then(() => {
          copyBtn.classList.add('copied');
          setTimeout(() => copyBtn.classList.remove('copied'), 2000);
        });
      });
    }
  });
  document.addEventListener('DOMContentLoaded', function () {
    const copyBtn = document.querySelector('.copy-link');
    const copiedMsg = document.querySelector('.copied-msg');

    if (copyBtn && copiedMsg) {
      copyBtn.addEventListener('click', () => {
        navigator.clipboard.writeText(window.location.href).then(() => {
          copiedMsg.classList.add('show');

          setTimeout(() => {
            copiedMsg.classList.remove('show');
          }, 1500);
        });
      });
    }
  });
{% endjavascript %}

